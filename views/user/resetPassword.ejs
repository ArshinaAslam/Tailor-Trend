<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        :root {
            --color-bg: #f5f4f0;
            --color-surface: #ffffff;
            --color-text: #1a1a1a;
            --color-text-muted: #888888;
            --color-accent: #1a1a1a;
            --color-accent-hover: #333333;
            --color-border: #e0e0e0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, Arial, sans-serif;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .card-login {
            background: var(--color-surface);
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            width: 100%;
            max-width: 400px;
        }

        .card-title {
            text-align: center;
            margin-bottom: 1.5rem;
            color: var(--color-text);
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .field-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--color-text-muted);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .input-container {
            position: relative;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            padding-right: 2.6rem;
            border: 1px solid var(--color-border);
            border-radius: 10px;
            font-size: 0.95rem;
            background-color: var(--color-bg);
            color: var(--color-text);
            transition: all 0.3s ease;
        }

        input:focus {
            border-color: var(--color-accent);
            outline: none;
            background-color: var(--color-surface);
            box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.06);
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--color-text-muted);
            font-size: 1rem;
            user-select: none;
        }

        .error-message {
            color: #c0392b;
            font-size: 0.8rem;
            margin-top: 0.4rem;
            min-height: 14px;
        }

        button {
            width: 100%;
            padding: 0.9rem;
            border: none;
            border-radius: 10px;
            background: var(--color-accent);
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            letter-spacing: 0.5px;
            margin-top: 0.5rem;
        }

        button:hover {
            background: var(--color-accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.12);
        }

        .alert {
            text-align: center;
            font-size: 0.85rem;
            color: #c0392b;
            background: #fdecea;
            border: 1px solid #f5c6cb;
            border-radius: 10px;
            padding: 0.7rem;
            margin-top: 1rem;
        }

        .login-link {
            text-align: center;
            margin-top: 1.2rem;
            font-size: 0.9rem;
            color: var(--color-text-muted);
        }

        .login-link a {
            color: var(--color-text);
            text-decoration: none;
            font-weight: 700;
        }

        .login-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="card-login">
        <h4 class="card-title">Change Password</h4>
        <form method="POST" action="/resetPassword" onsubmit="return validateForm()">
            <div class="field-group">
                <label for="newPass1">New Password</label>
                <div class="input-container">
                    <input type="password" name="newPass1" id="newPass1" placeholder="Enter new password">
                    <span class="toggle-password" onclick="togglePassword('newPass1', 'eye1')">
                        <i id="eye1" class="fa-solid fa-eye"></i>
                    </span>
                </div>
                <div id="newPass1Error" class="error-message"></div>
            </div>

            <div class="field-group">
                <label for="newPass2">Confirm New Password</label>
                <div class="input-container">
                    <input type="password" name="newPass2" id="newPass2" placeholder="Re-enter new password">
                    <span class="toggle-password" onclick="togglePassword('newPass2', 'eye2')">
                        <i id="eye2" class="fa-solid fa-eye"></i>
                    </span>
                </div>
                <div id="newPass2Error" class="error-message"></div>
            </div>

            <button type="submit">Change Password</button>

            <% if (locals.message && message.length > 0) { %>
                <div id="alertMessage" class="alert">
                    <%= message %>
                </div>
            <% } %>
        </form>

        <div class="login-link">
            Don't have an account? <a href="/signup">Sign up</a>
        </div>
    </div>

    <script>
        function togglePassword(fieldId, eyeId) {
            const field = document.getElementById(fieldId);
            const eyeIcon = document.getElementById(eyeId);
            if (field && eyeIcon) {
                field.type = field.type === "password" ? "text" : "password";
                eyeIcon.className = field.type === "password" ? "fa-solid fa-eye" : "fa-solid fa-eye-slash";
            }
        }

        function validateForm() {
            let valid = true;
            const newPass1 = document.getElementById('newPass1');
            const newPass2 = document.getElementById('newPass2');
            const newPass1Error = document.getElementById('newPass1Error');
            const newPass2Error = document.getElementById('newPass2Error');

            newPass1Error.textContent = '';
            newPass2Error.textContent = '';

            const passwordVal = newPass1.value.trim();
            const confirmVal = newPass2.value.trim();

            const uppercase = /[A-Z]/;
            const lowercase = /[a-z]/;
            const digit = /\d/;
            const specialChar = /[@#$%^&*!]/;

            if (!passwordVal) {
                newPass1Error.textContent = 'Password cannot be empty.';
                valid = false;
            } else if (passwordVal.length < 8) {
                newPass1Error.textContent = 'Password must be at least 8 characters long.';
                valid = false;
            } else if (!uppercase.test(passwordVal)) {
                newPass1Error.textContent = 'Password must contain at least one uppercase letter (A-Z).';
                valid = false;
            } else if (!lowercase.test(passwordVal)) {
                newPass1Error.textContent = 'Password must contain at least one lowercase letter (a-z).';
                valid = false;
            } else if (!digit.test(passwordVal)) {
                newPass1Error.textContent = 'Password must contain at least one number (0-9).';
                valid = false;
            } else if (!specialChar.test(passwordVal)) {
                newPass1Error.textContent = 'Password must contain at least one special character (@#$%^&*!).';
                valid = false;
            }

            if (!confirmVal) {
                newPass2Error.textContent = 'Please re-enter your password.';
                valid = false;
            } else if (passwordVal !== confirmVal) {
                newPass2Error.textContent = 'Passwords do not match.';
                valid = false;
            }

            return valid;
        }
    </script>
</body>
</html>