<%- include("../../views/partials/user/header") %>
<style>
  .profile-page {
    --color-bg: #f5f4f0;
    --color-surface: #ffffff;
    --color-text: #1a1a1a;
    --color-text-muted: #888888;
    --color-accent: #1a1a1a;
    --color-accent-hover: #333333;
    --color-border: #e0e0e0;
    --color-danger: #c0392b;
    --color-danger-hover: #a5301f;
    --space-1: 0.5rem;
    --space-2: 0.75rem;
    --space-3: 1rem;
    --space-4: 1.5rem;
    --space-5: 2rem;
  }

  .profile-page .card {
    border: none !important;
    border-radius: 16px !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06) !important;
    background: var(--color-surface) !important;
  }

  .profile-page .card-header {
    background: var(--color-surface) !important;
    border-bottom: 1px solid var(--color-border) !important;
    padding: var(--space-4) var(--space-5) !important;
  }

  .profile-page .card-header h5 {
    color: var(--color-text) !important;
    font-weight: 700 !important;
  }

  .profile-page .card-body {
    padding: var(--space-5) !important;
  }

  /* --- Profile view --- */
  .profile-page .profile-card .card-body {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .profile-page .profile-avatar {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .profile-page .profile-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .profile-page .profile-info h3 {
    color: var(--color-text) !important;
    font-weight: 700;
    margin: 0;
  }

  .profile-page .profile-info p {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  .profile-page .profile-info .btn-primary {
    margin-top: var(--space-2);
    align-self: flex-start;
  }

  /* --- Edit form --- */
  .profile-page .field {
    margin-bottom: var(--space-4);
  }

  .profile-page .field-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-1);
  }

  .profile-page .form-label {
    font-weight: 600 !important;
    color: var(--color-text-muted) !important;
    font-size: 0.9rem;
    margin: 0;
  }

  .profile-page .form-control {
    width: 100%;
    border: 1px solid var(--color-border) !important;
    border-radius: 10px !important;
    padding: 0.75rem 1rem !important;
    background-color: var(--color-bg) !important;
    color: var(--color-text) !important;
    transition: all 0.3s ease;
  }

  .profile-page .form-control:focus {
    border-color: var(--color-accent) !important;
    outline: none;
    background-color: var(--color-surface) !important;
    box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.06);
  }

  .profile-page .form-control[readonly] {
    background-color: #eeeeeb !important;
    color: var(--color-text-muted) !important;
  }

  .profile-page .text-danger {
    display: none;
    font-size: 0.8rem;
    margin-top: var(--space-1);
    color: var(--color-danger) !important;
  }

  .profile-page .field-action {
    margin-top: var(--space-2);
  }

  /* --- Buttons --- */
  .profile-page .btn-primary {
    background: var(--color-accent) !important;
    border: none !important;
    border-radius: 10px !important;
    color: #fff !important;
    font-weight: 600 !important;
    padding: 0.6rem 1.1rem !important;
    transition: all 0.3s ease;
  }

  .profile-page .btn-primary:hover {
    background: var(--color-accent-hover) !important;
    transform: translateY(-1px);
  }

  .profile-page .btn-danger {
    background: transparent !important;
    color: var(--color-danger) !important;
    border: 1px solid #f1c3bc !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    padding: 0.6rem 1.1rem !important;
  }

  .profile-page .btn-danger:hover {
    background: #fdecea !important;
  }

  .profile-page .form-actions {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .profile-page .form-actions .btn {
    flex: 0 0 auto;
    min-width: 140px;
    text-align: center;
  }
</style>

<main class="main profile-page">
  <div class="breadcrumb-wrap">
    <div class="container">
      <div class="breadcrumb">
        <a href="/" rel="nofollow">Home</a>
        <span></span> Profile <span></span> Account
      </div>
    </div>
  </div>

  <section class="py-4">
    <div class="dashboard-container">

      <%- include("../../views/partials/user/profile-sidebar") %>

      <div class="content-area">

        <div id="dashboard">
          <div class="card profile-card">
            <div class="card-header">
              <h5 class="mb-0">User Profile</h5>
            </div>
            <div class="card-body">
              <div class="profile-avatar">
                <%= user.name.charAt(0) %>
              </div>
              <div class="profile-info">
                <h3><%= user.name %></h3>
                <p><i class="fi-rs-phone"></i><%= user.phone %></p>
                <p><i class="fi-rs-envelope"></i><%= user.email %></p>
                <a class="btn btn-primary" onclick="editProfile()">Edit Profile</a>
              </div>
            </div>
          </div>
        </div>

        <div id="editProfile" style="display: none;">
          <div class="card">
            <div class="card-header">
              <h5 class="mb-0">Edit Profile</h5>
            </div>
            <div class="card-body">
              <form id="editProfileForm">
                <div class="field">
                  <div class="field-header">
                    <label class="form-label">Name</label>
                  </div>
                  <input type="text" name="name" class="form-control" value="<%= user.name %>">
                  <span class="text-danger" id="nameError">Name cannot be empty!</span>
                </div>

                <div class="field">
                  <div class="field-header">
                    <label class="form-label">Email</label>
                  </div>
                  <input type="email" name="email" class="form-control" value="<%= user.email %>" readonly>
                  <div class="field-action">
                    <a href="/updateEmail" class="btn btn-primary">Edit Email</a>
                  </div>
                </div>

                <div class="field">
                  <div class="field-header">
                    <label class="form-label">Phone</label>
                  </div>
                  <input type="tel" name="phone" class="form-control" value="<%= user.phone %>">
                  <span class="text-danger" id="phoneError">Phone cannot be empty!</span>
                </div>

                <% if (!user.googleId) { %>
                  <div class="field">
                    <a href="/updatePassword" class="btn btn-primary">Edit Password</a>
                  </div>
                <% } %>

                <div class="form-actions">
                  <button type="submit" class="btn btn-primary">Save Changes</button>
                  <button type="button" class="btn btn-danger" onclick="cancelEdit()">Cancel</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("../../views/partials/user/footer") %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  function editProfile() {
    document.getElementById('dashboard').style.display = "none";
    document.getElementById('editProfile').style.display = "block";

    document.querySelector('#editProfileForm input[name="name"]').value = "<%= user.name %>";
    document.querySelector('#editProfileForm input[name="phone"]').value = "<%= user.phone %>";

    document.getElementById('nameError').style.display = 'none';
    document.getElementById('phoneError').style.display = 'none';
  }

  function cancelEdit() {
    document.getElementById('editProfile').style.display = "none";
    document.getElementById('dashboard').style.display = "block";
  }

  document.getElementById('editProfileForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    const nameError = document.getElementById('nameError');
    const phoneError = document.getElementById('phoneError');

    nameError.style.display = 'none';
    phoneError.style.display = 'none';

    let hasError = false;
    if (!data.name.trim()) {
      nameError.style.display = 'block';
      hasError = true;
    }
    if (!data.phone.trim()) {
      phoneError.style.display = 'block';
      hasError = true;
    }

    if (hasError) {
      return;
    }

    const nameRegex = /^[A-Za-z\s]+$/;
    const phoneRegex = /^\d{10}$/;
    const allSameDigitsPattern = /^(\d)\1+$/;

    if (!nameRegex.test(data.name)) {
      Swal.fire({
        icon: 'error',
        title: 'Invalid Name',
        text: 'Name should only contain alphabets and spaces!'
      });
      return;
    }

    if (!phoneRegex.test(data.phone)) {
      Swal.fire({
        icon: 'error',
        title: 'Invalid Phone',
        text: 'Phone number must be 10 digits!'
      });
      return;
    }

    if (data.phone && allSameDigitsPattern.test(data.phone)) {
      Swal.fire({
        title: 'Error',
        text: 'Phone number cannot contain all the same digits.',
        icon: 'error'
      });
      return false;
    }

    try {
      const response = await fetch('/updateUserDetails', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include',
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (result.success) {
        Swal.fire({
          icon: 'success',
          title: 'Profile Updated!',
          text: result.message,
        }).then(() => {
          window.location.reload();
        });
      } else {
        Swal.fire({
          icon: 'error',
          title: 'Update Failed',
          text: result.message || 'Failed to update profile!',
        });
      }
    } catch (error) {
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'An error occurred. Please try again!',
      });
    }
  });
</script>