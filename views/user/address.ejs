<%- include("../../views/partials/user/header") %>

<style>
  #address {
    --color-bg: #f5f4f0;
    --color-surface: #ffffff;
    --color-text: #1a1a1a;
    --color-text-muted: #888888;
    --color-accent: #1a1a1a;
    --color-accent-hover: #333333;
    --color-border: #e0e0e0;
  }

  #address .card {
    border: none !important;
    border-radius: 16px !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06) !important;
  }

  #address .card-header {
    background: var(--color-surface) !important;
    border-bottom: 1px solid var(--color-border) !important;
    padding: 1.1rem 1.4rem !important;
  }

  #address .card-header h5 {
    color: var(--color-text) !important;
    font-weight: 700 !important;
  }

  #address .card-body {
    padding: 1.4rem !important;
  }

  #address address {
    color: var(--color-text) !important;
    font-style: normal;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  #address .card-body p {
    color: var(--color-text-muted) !important;
    margin-bottom: 0.35rem;
    font-size: 0.92rem;
  }

  #address .btn-primary {
    background-color: var(--color-accent) !important;
    border-color: var(--color-accent) !important;
    color: #fff !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    padding: 0.45rem 1rem !important;
    transition: all 0.3s ease;
  }

  #address .btn-primary:hover,
  #address .btn-primary:focus,
  #address .btn-primary:active {
    background-color: var(--color-accent-hover) !important;
    border-color: var(--color-accent-hover) !important;
    color: #fff !important;
    transform: translateY(-1px);
  }

  #address .btn-danger {
    background-color: transparent !important;
    color: #c0392b !important;
    border: 1px solid #f1c3bc !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    padding: 0.45rem 1rem !important;
  }

  #address .btn-danger:hover,
  #address .btn-danger:focus,
  #address .btn-danger:active {
    background-color: #fdecea !important;
    border-color: #f1c3bc !important;
    color: #c0392b !important;
  }

  #address .btn-secondary {
    background-color: var(--color-surface) !important;
    border: 1px solid var(--color-border) !important;
    color: var(--color-text) !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
  }

  #address .btn-secondary:hover,
  #address .btn-secondary:focus,
  #address .btn-secondary:active {
    background-color: var(--color-bg) !important;
    border-color: var(--color-text-muted) !important;
    color: var(--color-text) !important;
  }

  #address .btn-light {
    background-color: var(--color-accent) !important;
    border-color: var(--color-accent) !important;
    color: #fff !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    pointer-events: none;
  }

  #address .w-50 {
    background-color: var(--color-accent) !important;
    border: none !important;
    color: #fff !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    padding: 0.8rem !important;
    transition: all 0.3s ease;
  }

  #address .w-50:hover,
  #address .w-50:focus,
  #address .w-50:active {
    background-color: var(--color-accent-hover) !important;
    color: #fff !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.12);
  }

  #address .address-item {
    margin-bottom: 1.25rem;
  }
</style>

<main class="main">
  <div class="breadcrumb-wrap">
    <div class="container">
      <div class="breadcrumb">
        <a href="/" rel="nofollow">Home</a>
        <span></span> Profile <span></span> My Address
      </div>
    </div>
  </div>

  <section class="py-4">
    <div class="dashboard-container">

      <%- include("../../views/partials/user/profile-sidebar") %>

      <div class="content-area">

        <div id="address">
          <div class="row" id="address-container">
            <% if (userAddress && userAddress.address.length > 0) { %>
              <% userAddress.address.forEach((address, index) => { %>
                <div class="col-lg-6 address-item">
                  <div class="card mb-3 mb-lg-0">
                    <div class="card-header">
                      <h5 class="mb-0"><%= address.addressType %></h5>
                    </div>
                    <div class="card-body">
                      <address>
                        <%= address.name %><br>
                        <%= address.city %><br>
                        <%= address.landMark %><br>
                        <%= address.state %><br>
                      </address>
                      <p><%= address.pincode %></p>
                      <p><%= address.phone %></p>
                      <p><%= address.altPhone %></p>

                      <div class="d-flex justify-content-between">
                        <a href="/editAddress?id=<%= address._id %>" class="btn btn-sm btn-primary">Edit</a>
                        <a href="#" class="btn btn-sm btn-danger" onclick="confirmDelete('<%= address._id %>')">Delete</a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="col-lg-6 address-item">
                <div class="card mb-3 mb-lg-0">
                  <div class="card-header">
                    <h5 class="mb-0">No Address</h5>
                  </div>
                  <div class="card-body">
                    <address>No address available</address>
                  </div>
                </div>
              </div>
            <% } %>
          </div>

          <div class="d-flex justify-content-center align-items-center mt-3">
            <% if (currentPage > 1) { %>
              <a href="?page=<%= currentPage - 1 %>" class="btn btn-secondary me-2">Previous</a>
            <% } %>

            <span class="btn btn-light">Page <%= currentPage %> of <%= totalPages %></span>

            <% if (currentPage < totalPages) { %>
              <a href="?page=<%= currentPage + 1 %>" class="btn btn-secondary ms-2">Next</a>
            <% } %>
          </div>

          <div class="mt-3 text-center text-lg-start">
            <a href="/addAddress">
              <button class="btn w-50">Add Address</button>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("../../views/partials/user/footer") %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  function changePage(page) {
    window.location.href = `/my-address?page=${page}`;
  }

  function confirmDelete(addressId) {
    Swal.fire({
      title: 'Are you sure?',
      text: 'You are about to delete this address. This action cannot be undone!',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#c0392b',
      cancelButtonColor: '#888888',
      confirmButtonText: 'Yes, delete it!',
      cancelButtonText: 'Cancel',
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = `/deleteAddress?id=${addressId}`;
      }
    });
  }
</script>