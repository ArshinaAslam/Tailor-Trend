<%- include("../../views/partials/user/header") %>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <style>
        :root {
            --color-bg: #f5f4f0;
            --color-surface: #ffffff;
            --color-text: #1a1a1a;
            --color-text-muted: #888888;
            --color-accent: #1a1a1a;
            --color-accent-hover: #333333;
            --color-border: #e0e0e0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, Arial, sans-serif;
        }

        html, body {
            height: 100%;
        }

        .page-container {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: var(--color-bg);
        }

        .content-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem 0;
        }

        form {
            background: var(--color-surface);
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            max-width: 400px;
            width: 100%;
            text-align: center;
        }

        form h3 {
            margin-bottom: 1.2rem;
            color: var(--color-text);
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--color-text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            text-align: left;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            margin-bottom: 1rem;
            border: 1px solid var(--color-border);
            border-radius: 10px;
            font-size: 0.95rem;
            background-color: var(--color-bg);
            color: var(--color-text);
            text-align: center;
            letter-spacing: 4px;
            transition: all 0.3s ease;
        }

        input:focus {
            border-color: var(--color-accent);
            outline: none;
            background-color: var(--color-surface);
            box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.06);
        }

        button {
            width: 100%;
            padding: 0.9rem;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            letter-spacing: 0.5px;
            margin-bottom: 0.6rem;
        }

        button[type="submit"] {
            background: var(--color-accent);
            color: white;
        }

        button[type="submit"]:hover {
            background: var(--color-accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.12);
        }

        #resendOtp {
            background: var(--color-surface);
            color: var(--color-text);
            border: 1px solid var(--color-border);
        }

        #resendOtp:hover:not(:disabled) {
            background: var(--color-bg);
            border-color: var(--color-text-muted);
        }

        #resendOtp:disabled {
            color: var(--color-text-muted);
            cursor: not-allowed;
        }

        .link {
            font-size: 0.9rem;
            color: var(--color-text-muted);
            margin-top: 0.6rem;
        }

        .link a {
            color: var(--color-text);
            text-decoration: none;
            font-weight: 700;
        }

        .link a:hover {
            text-decoration: underline;
        }

        #otpTimer {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--color-bg);
            color: var(--color-text);
            font-size: 1.2rem;
            font-weight: 700;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 10px auto;
            border: 2px solid var(--color-border);
            transition: background 0.5s;
        }

        #otpTimer.expired {
            background: #c0392b;
            color: white;
            border-color: #c0392b;
        }
    </style>
</head>
<body>
    <div class="page-container">

        <div class="content-container">
            <form id="otpForm" method="post" action="#" onsubmit="return validateOTPForm(event)">
                <h3>Verify Your Email</h3>
                <label for="otp">Enter OTP :</label>
                <input type="text" id="otp" name="otp" maxlength="6" pattern="[0-9]{6}" placeholder="Enter 6-digit OTP" required>
                <button type="submit">Verify Email</button>

                <!--  Timer -->
                <div id="otpTimer">
                    <span id="timerValue">60</span>
                </div>

                <button type="button" id="resendOtp" onclick="resendOTP()" disabled>Resend OTP</button>
                <div class="link">Already verified? <a href="/login">Login now</a></div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let timer = 60;
        let timerInterval;

        function startTimer() {
            timerInterval = setInterval(() => {
                timer--;
                document.getElementById('timerValue').textContent = timer;

                if (timer <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('otpTimer').classList.add("expired");
                    document.getElementById('timerValue').textContent = "X";
                    document.getElementById('resendOtp').disabled = false;
                    swal.fire({
                        icon: "warning",
                        title: "OTP Expired",
                        text: "Please request a new OTP."
                    });
                }
            }, 1000);
        }

        startTimer();

        function validateOTPForm(event) {
            event.preventDefault();
            const otpInput = document.getElementById('otp').value;

            $.ajax({
                type: 'POST',
                url: 'verifyOtp',
                data: { otp: otpInput, timer },
                success: function(response) {
                    if (response.success) {
                        swal.fire({
                            icon: "success",
                            title: "OTP verified successfully",
                            showConfirmButton: false,
                            timer: 1500
                        }).then(() => {
                            window.location.href = response.redirectUrl;
                        });
                    } else {
                        swal.fire({
                            icon: "error",
                            title: "Error",
                            text: response.message
                        });
                    }
                },
                error: function() {
                    swal.fire({
                        icon: "error",
                        title: "Invalid OTP",
                        text: "Please try again"
                    });
                }
            });

            return false;
        }

        async function resendOTP() {
            clearInterval(timerInterval);
            timer = 60;
            document.getElementById('resendOtp').disabled = true;
            document.getElementById('otpTimer').classList.remove("expired");
            startTimer();

            const response = await fetch('/resendOtpp', {
                method: 'POST',
                headers: {
                    'Content-type': 'application/json'
                }
            });

            const result = await response.json();
            console.log('result of the request: ', result);

            if (result.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: 'OTP sent successfully',
                    confirmButtonColor: '#1a1a1a'
                });
                return;
            }

            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: 'Error while sending the OTP',
                confirmButtonColor: '#c0392b'
            });

            return false;
        }
    </script>
</body>
</html>
<%- include("../../views/partials/user/footer") %>