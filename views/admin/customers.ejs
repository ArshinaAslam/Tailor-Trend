<%- include("../../views/partials/admin/header") %>
<title>Customers</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.css"/>

<style>

body {
  background: var(--admin-bg-gradient);
  font-family: 'Poppins', sans-serif;
  color: var(--admin-text);
  margin: 0;
  padding: 0;
}

.dashboard-container {
  padding: 3rem;
  max-width: 1400px;
  margin: 0 auto;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 2rem;
}

.dashboard-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0;
  color: var(--admin-text);
  letter-spacing: -0.025em;
  text-transform: uppercase;
}

/* Search bar, styled like the dashboard's filters section */
.search-form {
  display: flex;
  align-items: center;
  background: var(--admin-surface);
  border: 1px solid var(--admin-border);
  border-radius: 30px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  max-width: 420px;
}

.search-form input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  color: var(--admin-text);
  padding: 0.75rem 1.25rem;
  font-size: 0.95rem;
}

.search-form input::placeholder {
  color: var(--admin-text-dim);
}

.search-form button {
  background: var(--admin-accent);
  color: #ffffff;
  border: none;
  padding: 0.75rem 1.5rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.3s ease;
}

.search-form button:hover {
  background: var(--admin-accent-hover);
}

/* Table, matching dashboard's table-container / data-table */
.table-container {
  background: var(--admin-surface);
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  overflow: hidden;
  border: 1px solid var(--admin-border);
  margin-bottom: 2.5rem;
}

.data-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 0.95rem;
}

.data-table th {
  background: var(--admin-surface-alt);
  color: var(--admin-text-muted);
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.85rem;
  padding: 1.25rem;
  letter-spacing: 0.05em;
  text-align: center;
  border-bottom: 2px solid var(--admin-border);
}

.data-table td {
  padding: 1.25rem;
  border-bottom: 1px solid var(--admin-border);
  color: var(--admin-text);
  text-align: center;
}

.data-table tbody tr {
  transition: background 0.3s ease;
}

.data-table tbody tr:hover {
  background: var(--admin-surface-hover);
}

/* Action buttons, matching dashboard icon accent colors */
.btn-block,
.btn-unblock {
  padding: 0.5rem 1.25rem;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.85rem;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  color: #ffffff;
}

.btn-block {
  background: var(--admin-red);
}

.btn-block:hover {
  filter: brightness(1.1);
}

.btn-unblock {
  background: var(--admin-green);
}

.btn-unblock:hover {
  filter: brightness(1.1);
}

/* Pagination, matching dashboard's btn-filter styling */
.pagination-container {
  display: flex;
  justify-content: center;
}

.pagination {
  display: flex;
  list-style: none;
  gap: 0.5rem;
  padding: 0;
  margin: 0;
}

.page-item .page-link {
  display: inline-block;
  padding: 0.6rem 1.1rem;
  background: var(--admin-surface-alt);
  border: 1px solid var(--admin-border);
  border-radius: 8px;
  color: var(--admin-text-muted);
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}

.page-item .page-link:hover {
  background: var(--admin-surface-hover);
  border-color: var(--admin-accent);
  color: var(--admin-text);
}

.page-item.active .page-link {
  background: var(--admin-accent);
  color: #ffffff;
  border-color: var(--admin-accent);
}

.page-item.disabled .page-link {
  opacity: 0.4;
  pointer-events: none;
}

@media (max-width: 576px) {
  .content-header {
    flex-direction: column;
    align-items: stretch;
  }

  .search-form {
    max-width: 100%;
  }
}
</style>

<div class="dashboard-container">
  <div class="content-header">
    <h2 class="dashboard-title">Customers</h2>
    <form action="/admin/users/" method="get" class="search-form">
      <input type="text" placeholder="Search customers..." name="search" value="<%= search %>">
      <button type="submit">Search</button>
    </form>
  </div>

  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr>
          <th scope="col">Name</th>
          <th scope="col">Email</th>
          <th scope="col">Phone No</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        <% for(let i=0;i<data.length;i++){%>
          <tr>
            <td><%=data[i].name%></td>
            <td><%=data[i].email%></td>
            <td><%=data[i].phone%></td>
            <td>
              <% if (data[i].isBlocked === false) { %>
                <button class="btn-block" onclick="confirmBlock('<%= data[i]._id %>', 'block')">Block</button>
              <% } else { %>
                <button class="btn-unblock" onclick="confirmBlock('<%= data[i]._id %>', 'unblock')">Unblock</button>
              <% } %>
            </td>
          </tr>
        <%}%>
      </tbody>
    </table>
  </div>

  <div class="pagination-container">
    <nav>
      <ul class="pagination">
        <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search %>">Previous</a>
        </li>

        <% for(let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === currentPage ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %>&search=<%= search %>"><%= i %></a>
          </li>
        <% } %>

        <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search %>">Next</a>
        </li>
      </ul>
    </nav>
  </div>
</div>

<%- include("../../views/partials/admin/footer") %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script>
function confirmBlock(customerId, action) {
    const actionText = action === 'block' ? 'Block' : 'Unblock';
    const actionUrl = action === 'block' ? `/admin/blockCustomer?id=${customerId}` : `/admin/unblockCustomer?id=${customerId}`;

    Swal.fire({
        title: `Are you sure?`,
        text: `Do you want to ${actionText.toLowerCase()} this customer?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: action === 'block' ? '#ef4444' : '#10b981',
        cancelButtonColor: '#6c757d',
        confirmButtonText: `Yes, ${actionText} them!`,
        background: '#2a2a2a',
        color: '#ffffff'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = actionUrl;
        }
    });
}
</script>
