<%- include("../../views/partials/admin/header") %>
<title>Wallet Transactions</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>

body {
  background: var(--admin-bg-gradient);
  font-family: 'Poppins', sans-serif;
  color: var(--admin-text);
  margin: 0;
  padding: 0;
}

.dashboard-container {
  padding: 3rem;
  max-width: 1400px;
  margin: 0 auto;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 2rem;
}

.dashboard-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0;
  color: var(--admin-text);
  letter-spacing: -0.025em;
  text-transform: uppercase;
}

.header-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
}

.search-form {
  display: flex;
  align-items: center;
  background: var(--admin-surface);
  border: 1px solid var(--admin-border);
  border-radius: 30px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
}

.search-form input {
  border: none;
  outline: none;
  background: transparent;
  color: var(--admin-text);
  padding: 0.75rem 1.25rem;
  font-size: 0.95rem;
  width: 280px;
}

.search-form input::placeholder {
  color: var(--admin-text-dim);
}

.search-form button {
  background: var(--admin-accent);
  color: #ffffff;
  border: none;
  padding: 0.75rem 1.5rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.3s ease;
}

.search-form button:hover {
  background: var(--admin-accent-hover);
}

.search-hint {
  font-size: 0.78rem;
  color: var(--admin-text-dim);
  margin: 0;
}


.table-container {
  background: var(--admin-surface);
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  overflow: hidden;
  border: 1px solid var(--admin-border);
  margin-bottom: 1.5rem;
}

.table-container-inner {
  padding: 1.5rem;
}

.data-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 0.9rem;
}

.data-table th {
  background: var(--admin-surface-alt);
  color: var(--admin-text-muted);
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.8rem;
  padding: 1.1rem;
  letter-spacing: 0.05em;
  text-align: center;
  border-bottom: 2px solid var(--admin-border);
}

.data-table td {
  padding: 1.1rem;
  border-bottom: 1px solid var(--admin-border);
  color: var(--admin-text);
  text-align: center;
  vertical-align: middle;
}

.data-table tbody tr {
  transition: background 0.3s ease;
}

.data-table tbody tr:hover {
  background: var(--admin-surface-hover);
}

.badge {
  display: inline-block;
  padding: 0.3rem 0.9rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.03em;
}

.badge-credit {
  background: rgba(16, 185, 129, 0.15);
  color: var(--admin-green);
}

.badge-debit {
  background: rgba(239, 68, 68, 0.15);
  color: var(--admin-red);
}

.amount-credit {
  color: var(--admin-green);
  font-weight: 700;
}

.amount-debit {
  color: var(--admin-red);
  font-weight: 700;
}

.btn-view {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 1.1rem;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.8rem;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  color: #ffffff;
  text-decoration: none;
  background: var(--admin-blue);
}

.btn-view:hover {
  filter: brightness(1.1);
  color: #ffffff;
}

/* Pagination footer */
.pagination-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  border-top: 1px solid var(--admin-border);
}

.pagination-summary {
  font-size: 0.85rem;
  color: var(--admin-text-muted);
}

.pagination-summary strong {
  color: var(--admin-text);
}

.pagination-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.pagination-container a,
.pagination-container span {
  display: inline-flex;
  align-items: center;
  padding: 0.6rem 1.1rem;
  background: var(--admin-surface-alt);
  border: 1px solid var(--admin-border);
  border-radius: 8px;
  color: var(--admin-text-muted);
  text-decoration: none;
  font-weight: 600;
  font-size: 0.85rem;
  transition: all 0.3s ease;
}

.pagination-container a:hover {
  background: var(--admin-surface-hover);
  border-color: var(--admin-accent);
  color: var(--admin-text);
}

.pagination-container .current-page {
  background: var(--admin-accent);
  color: #ffffff;
  border-color: var(--admin-accent);
}

.pagination-container .ellipsis {
  color: var(--admin-text-dim);
  border: none;
  background: transparent;
  padding: 0.6rem 0.3rem;
}

.empty-row td {
  text-align: center;
  padding: 2rem;
  color: var(--admin-text-dim);
}

@media (max-width: 768px) {
  .content-header {
    flex-direction: column;
    align-items: stretch;
  }

  .header-actions {
    align-items: stretch;
  }

  .search-form input {
    width: 100%;
  }

  .data-table {
    font-size: 0.8rem;
  }

  .pagination-footer {
    flex-direction: column;
    align-items: stretch;
    text-align: center;
  }
}
</style>

<div class="dashboard-container">
  <div class="content-header">
    <h2 class="dashboard-title">Wallet Transactions</h2>
    <div class="header-actions">
      <form action="/admin/wallet-transaction" method="GET" class="search-form">
        <input
          type="text"
          name="query"
          placeholder="Search by ID, Type or Date"
          value="<%= searchQuery %>"
        >
        <button type="submit">
          <i class="fas fa-search"></i>
        </button>
      </form>
      <p class="search-hint">Search tips: Use Transaction ID, Type (credit/debit) or Date</p>
    </div>
  </div>

  <div class="table-container">
    <div class="table-container-inner">
      <table class="data-table">
        <thead>
          <tr>
            <th>Transaction ID</th>
            <th>Transaction Date</th>
            <th>User</th>
            <th>Transaction Type</th>
            <th>Amount</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (transactions && transactions.length > 0) { %>
            <% transactions.forEach(function(transaction) { %>
              <tr>
                <td><%= transaction.transactionId %></td>
                <td>
                  <%= new Date(transaction.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                  }) %>
                </td>
                <td><%= transaction.userId.name || 'N/A' %></td>
                <td>
                  <span class="badge <%= transaction.type === 'credit' ? 'badge-credit' : 'badge-debit' %>">
                    <%= transaction.type.toUpperCase() %>
                  </span>
                </td>
                <td>
                  <span class="<%= transaction.type === 'credit' ? 'amount-credit' : 'amount-debit' %>">
                    <%= transaction.type === 'credit' ? '+' : '-' %>₹<%= transaction.amount.toFixed(2) %>
                  </span>
                </td>
                <td>
                  <a href="/admin/wallet-transaction/<%= transaction._id %>" class="btn-view">
                    <i class="fas fa-eye"></i> View
                  </a>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr class="empty-row">
              <td colspan="6">No transactions found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-footer">
      <div class="pagination-summary">
        Showing
        <strong><%= (currentPage - 1) * 10 + 1 %></strong>
        to
        <strong><%= Math.min(currentPage * 10, totalTransactions) %></strong>
        of
        <strong><%= totalTransactions %></strong>
        transactions
      </div>

      <nav aria-label="Pagination" class="pagination-container">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>">
            <i class="fas fa-chevron-left" style="margin-right: 6px;"></i>Previous
          </a>
        <% } %>

        <%
        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, currentPage + 2);

        if (startPage > 1) { %>
          <a href="?page=1<%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>">1</a>
          <% if (startPage > 2) { %>
            <span class="ellipsis">...</span>
          <% }
        }

        for (let i = startPage; i <= endPage; i++) { %>
          <% if (i === currentPage) { %>
            <span class="current-page"><%= i %></span>
          <% } else { %>
            <a href="?page=<%= i %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>"><%= i %></a>
          <% } %>
        <% } %>

        <% if (endPage < totalPages) { %>
          <% if (endPage < totalPages - 1) { %>
            <span class="ellipsis">...</span>
          <% } %>
          <a href="?page=<%= totalPages %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>">
            <%= totalPages %>
          </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>">
            Next<i class="fas fa-chevron-right" style="margin-left: 6px;"></i>
          </a>
        <% } %>
      </nav>
    </div>
  </div>
</div>

<%- include("../../views/partials/admin/footer") %>