<%- include("../../views/partials/admin/header") %>
<title>Products</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.css">

<style>

body {
  background: var(--admin-bg-gradient);
  font-family: 'Poppins', sans-serif;
  color: var(--admin-text);
  margin: 0;
  padding: 0;
}

.dashboard-container {
  padding: 3rem;
  max-width: 1400px;
  margin: 0 auto;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 2rem;
}

.dashboard-title {
  font-size: 2.5rem;
  font-weight: 700;
  margin: 0;
  color: var(--admin-text);
  letter-spacing: -0.025em;
  text-transform: uppercase;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.search-form {
  display: flex;
  align-items: center;
  background: var(--admin-surface);
  border: 1px solid var(--admin-border);
  border-radius: 30px;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
}

.search-form input {
  border: none;
  outline: none;
  background: transparent;
  color: var(--admin-text);
  padding: 0.75rem 1.25rem;
  font-size: 0.95rem;
  width: 260px;
}

.search-form input::placeholder {
  color: var(--admin-text-dim);
}

.search-form button {
  background: var(--admin-accent);
  color: #ffffff;
  border: none;
  padding: 0.75rem 1.5rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.3s ease;
}

.search-form button:hover {
  background: var(--admin-accent-hover);
}

.btn-add-product {
  padding: 0.75rem 1.5rem;
  background: var(--admin-green);
  color: #ffffff;
  border: none;
  border-radius: 30px;
  font-weight: 600;
  cursor: pointer;
  transition: filter 0.3s ease;
  text-decoration: none;
  white-space: nowrap;
}

.btn-add-product:hover {
  filter: brightness(1.1);
  color: #ffffff;
}

/* Table, matching dashboard's table-container / data-table */
.table-container {
  background: var(--admin-surface);
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  overflow: hidden;
  border: 1px solid var(--admin-border);
  margin-bottom: 2.5rem;
}

.data-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  font-size: 0.9rem;
}

.data-table th {
  background: var(--admin-surface-alt);
  color: var(--admin-text-muted);
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.8rem;
  padding: 1.1rem;
  letter-spacing: 0.05em;
  text-align: center;
  border-bottom: 2px solid var(--admin-border);
}

.data-table td {
  padding: 1.1rem;
  border-bottom: 1px solid var(--admin-border);
  color: var(--admin-text);
  text-align: center;
}

.data-table td p {
  margin: 0.2rem 0;
  color: var(--admin-text-muted);
  font-size: 0.85rem;
}

.data-table tbody tr {
  transition: background 0.3s ease;
}

.data-table tbody tr:hover {
  background: var(--admin-surface-hover);
}

/* Action buttons, consistent pill style using dashboard accent colors */
.btn {
  display: inline-block;
  padding: 0.5rem 1.1rem;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.8rem;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  color: #ffffff;
  text-decoration: none;
}

.btn-offer {
  background: var(--admin-blue);
}

.btn-offer:hover {
  filter: brightness(1.1);
}

.btn-remove-offer {
  background: var(--admin-red);
}

.btn-remove-offer:hover {
  filter: brightness(1.1);
}

.btn-block {
  background: var(--admin-red);
}

.btn-block:hover {
  filter: brightness(1.1);
}

.btn-unblock {
  background: var(--admin-green);
}

.btn-unblock:hover {
  filter: brightness(1.1);
}

.btn-edit {
  background: var(--admin-surface-hover);
  border: 1px solid var(--admin-border);
}

.btn-edit:hover {
  background: var(--admin-accent);
  border-color: var(--admin-accent);
}

/* Pagination, matching dashboard's btn-filter styling */
.pagination-container {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  margin-top: 1.5rem;
}

.pagination-container a,
.pagination-container span {
  display: inline-block;
  padding: 0.6rem 1.1rem;
  background: var(--admin-surface-alt);
  border: 1px solid var(--admin-border);
  border-radius: 8px;
  color: var(--admin-text-muted);
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}

.pagination-container a:hover {
  background: var(--admin-surface-hover);
  border-color: var(--admin-accent);
  color: var(--admin-text);
}

.pagination-container .current-page {
  background: var(--admin-accent);
  color: #ffffff;
  border-color: var(--admin-accent);
}

@media (max-width: 768px) {
  .content-header {
    flex-direction: column;
    align-items: stretch;
  }

  .header-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .search-form input {
    width: 100%;
  }

  .data-table {
    font-size: 0.8rem;
  }
}
</style>

<div class="dashboard-container">
  <div class="content-header">
    <h2 class="dashboard-title">Products</h2>
    <div class="header-actions">
      <form action="" method="get" class="search-form">
        <input type="text" placeholder="Search products or brands" name="search">
        <button type="submit">Search</button>
      </form>
      <a href="/admin/addProducts" class="btn-add-product">Add Product</a>
    </div>
  </div>

  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr>
          <th>Product Name</th>
          <th>Brand</th>
          <th>Category</th>
          <th>Sale Price</th>
          <th>Offer Price</th>
          <th>Offer</th>
          <th>Size and Quantity</th>
          <th>Action</th>
          <th>Edit</th>
        </tr>
      </thead>
      <tbody>
        <% for (let i = data.length - 1; i >= 0; i--) { %>
        <tr>
          <td><%= data[i].productName %></td>
          <td><%= data[i].brand %></td>
          <td><%= data[i].category ? data[i].category.name : 'No Category' %></td>
          <td>₹<%= data[i].salePrice %></td>
          <td>
            <%if(data[i].productOffer){%>
              <%=data[i].productOffer%>%
            <%}else{%>
              0%
            <%}%>
          </td>
          <td>
            <%if(data[i].productOffer===0){%>
              <a href="#" class="btn btn-offer" onclick="addOffer('<%=data[i]._id%>')">Add Offer</a>
            <%}else{%>
              <a href="#" class="btn btn-remove-offer" onclick="removeOffer('<%=data[i]._id%>')">Remove</a>
            <%}%>
          </td>
          <td>
            <% if (data[i].sizes && data[i].sizes.length > 0) { %>
              <% data[i].sizes.forEach(sizeObj => { %>
                <p><strong><%= sizeObj.size %></strong>: <%= sizeObj.quantity %></p>
              <% }) %>
            <% } else { %>
              No Sizes Available
            <% } %>
          </td>
          <td>
            <% if (data[i].isBlocked === false) { %>
              <button class="btn btn-block" onclick="confirmBlock('<%= data[i]._id %>', 'block')">Block</button>
            <% } else { %>
              <button class="btn btn-unblock" onclick="confirmBlock('<%= data[i]._id %>', 'unblock')">Unblock</button>
            <% } %>
          </td>
          <td>
            <a href="/admin/editProduct?id=<%= data[i]._id %>" class="btn btn-edit">Edit</a>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination-container">
    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>">&laquo; Previous</a>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <% if (i === currentPage) { %>
        <span class="current-page"><%= i %></span>
      <% } else { %>
        <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
      <% } %>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= Number(currentPage) + 1 %><%= search ? '&search=' + search : '' %>">Next &raquo;</a>
    <% } %>
  </div>
</div>

<%- include("../../views/partials/admin/footer") %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10/dist/sweetalert2.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script>
    function confirmBlock(productId, action) {
        const actionText = action === 'block' ? 'Block' : 'Unblock';
        const actionUrl = action === 'block' ? `/admin/blockedProduct?id=${productId}` : `/admin/unblockedProduct?id=${productId}`;

        Swal.fire({
            title: `Are you sure?`,
            text: `Do you want to ${actionText.toLowerCase()} this product?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: action === 'block' ? '#ef4444' : '#10b981',
            cancelButtonColor: '#6c757d',
            confirmButtonText: `Yes, ${actionText} it!`,
            background: '#2a2a2a',
            color: '#ffffff'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = actionUrl;
            }
        });
    }

    async function addOffer(productId) {
        const { value: amount } = await Swal.fire({
            title: 'Enter Offer Percentage',
            input: 'number',
            inputLabel: 'Percentage (%)',
            inputPlaceholder: 'Enter percentage (1-99)',
            inputAttributes: {
                min: 1,
                max: 99,
                step: 1
            },
            showCancelButton: true,
            confirmButtonText: 'Add Offer',
            cancelButtonText: 'Cancel',
            background: '#2a2a2a',
            color: '#ffffff',
            customClass: {
                validationMessage: 'my-validation-message'
            },
            inputValidator: (value) => {
                const parsedValue = parseInt(value);
                if (!value || isNaN(parsedValue) || parsedValue < 1 || parsedValue > 99) {
                    return 'Offer must be between 1% and 99%!';
                }
                return null;
            }
        });

        if (!amount) return;

        const parsedAmount = parseInt(amount);

        try {
            const response = await $.ajax({
                url: '/admin/addOffer-product',
                method: 'POST',
                data: {
                    percentage: parsedAmount,
                    productId: productId
                }
            });

            if (response.status === true) {
                await Swal.fire({
                    title: 'Success',
                    text: 'The offer has been added successfully!',
                    icon: 'success',
                    confirmButtonText: 'OK',
                    background: '#2a2a2a',
                    color: '#ffffff'
                });
                location.reload();
            } else {
                throw new Error(response.message || 'Failed to add offer');
            }
        } catch (error) {
            await Swal.fire({
                title: 'Error',
                text: error.message || 'An unexpected error occurred',
                icon: 'error',
                confirmButtonText: 'OK',
                background: '#2a2a2a',
                color: '#ffffff'
            });
        }
    }

    async function removeOffer(productId) {
        try {
            const result = await Swal.fire({
                title: 'Remove Offer',
                text: 'Are you sure you want to remove this offer?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#ef4444',
                confirmButtonText: 'Yes, remove it!',
                cancelButtonText: 'Cancel',
                timer: 5000,
                timerProgressBar: true,
                background: '#2a2a2a',
                color: '#ffffff'
            });

            if (!result.isConfirmed) return;

            const response = await $.ajax({
                url: '/admin/removeOffer-product',
                method: 'POST',
                data: {
                    productId: productId
                }
            });

            if (response.status === true) {
                await Swal.fire({
                    title: 'Removed!',
                    text: 'The offer has been removed successfully.',
                    icon: 'success',
                    confirmButtonText: 'OK',
                    background: '#2a2a2a',
                    color: '#ffffff'
                });
                location.reload();
            } else {
                throw new Error(response.message || 'Failed to remove offer');
            }
        } catch (error) {
            await Swal.fire({
                title: 'Error',
                text: error.message || 'An unexpected error occurred',
                icon: 'error',
                confirmButtonText: 'OK',
                background: '#2a2a2a',
                color: '#ffffff'
            });
        }
    }
</script>
